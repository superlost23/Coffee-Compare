# Copy to .env and fill in.

# --- Database ---
DATABASE_URL=postgresql+psycopg://coffee:coffee@db:5432/coffee_compare

# --- Meilisearch ---
MEILI_URL=http://meili:7700
MEILI_MASTER_KEY=change-me-to-a-long-random-string

# --- Anthropic API (for LLM extraction fallback) ---
ANTHROPIC_API_KEY=sk-ant-...
EXTRACTION_MODEL=claude-sonnet-4-5

# --- Admin ---
# Hidden URL: /admin-{ADMIN_PATH_TOKEN}
ADMIN_PATH_TOKEN=change-me-to-a-random-token-32-chars
ADMIN_USERNAME=admin
# Use a strong password; HTTP basic over HTTPS is fine for personal-use admin
ADMIN_PASSWORD=change-me-too

# --- Scraping ---
SCRAPE_USER_AGENT="CoffeeCompareBot/0.1 (+contact: you@example.com)"
SCRAPE_REQUEST_DELAY_MS=1000
SCRAPE_TIMEOUT_S=30

# --- Currency conversion (optional) ---
OPENEXCHANGERATES_APP_ID=
